# ----- Database -----
DATABASE_URL=postgres://user:pass@localhost:5432/mcg_support

# ----- CampusLogin (server-only) -----
CAMPUSLOGIN_API_KEY=
CAMPUSLOGIN_BASE_URL=https://connectorapi.campuslogin.com
CAMPUSLOGIN_ORG_ID=900
# TBD — request mailListId for active students from CampusLogin support
CAMPUSLOGIN_STUDENT_MAILLIST_ID=

# ----- Moodle (server-only) -----
MOODLE_BASE_URL=https://mcgcollege.lingellearning.ca
MOODLE_API_TOKEN=

# ----- Anthropic (server-only) -----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ----- OpenAI Embeddings (server-only) -----
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# ----- Resend (server-only) -----
RESEND_API_KEY=
RESEND_FROM_EMAIL="MCG Support <no-reply@support.mcgcollege.com>"

# ----- Sentry -----
SENTRY_DSN=

# ----- App -----
APP_URL=http://localhost:3000
NODE_ENV=development

# 32+ random bytes (base64). Generate: openssl rand -base64 48
SESSION_SECRET=
# 32 bytes (base64). Generate: openssl rand -base64 32
ENCRYPTION_KEY=

SUPPORT_HELPDESK_EMAIL=dj.gupta@mcgcollege.com

# Optional: set to "true" to allow magic-link tokens to be logged in dev
DEV_LOG_MAGIC_LINKS=false
